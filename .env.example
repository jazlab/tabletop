# Do not modify this .env.example !!!!
# Make any modifications to your own personal .env file (which is automatically
# generated with the tt-gen-env command, which just copies .env.example if .env
# does not exist

###############################################################################
#### User Configuration (REQUIRED) ############################################
###############################################################################

# ROS base image to use for building the TableTop docker container image
ROS_BASE_IMAGE=ros:jazzy@sha256:ce6609ec2188d0eadd61640fb598c0aff629a84d88970423b8f341ead2515683

# User name, uid, and gid for building the TableTop docker container image
USER_NAME=mules
USER_UID=1000
USER_GID=1000

# Display number for novnc server
NOVNC_DISPLAY=:20.0

# CUDA version to use, if NVIDIA is available
CUDA_VERSION=130

# Workspace bind mount consistency
BIND_CONSISTENCY=cached

###############################################################################
#### User Configuration (OPTIONAL) ############################################
###############################################################################

# Alternate ROS bag directory on host machine
# Useful if you want to use a different hard drive to store recorded data
# Leave unset to keep the default ROS_BAG_DIR set in setup.bash
ROS_BAG_DIR_HOST=

###############################################################################
#### Constants ################################################################
#### DO NOT TOUCH! ############################################################
#### (unless you really know what you're doing) ###############################
###############################################################################

# Maximum number of flir devices, as dictated by the limitations of the compose.yaml file
# If you exceed this limit, just add more FLIR_DEV_* entries to compose.yaml, then
# compose.yaml file must be
# modified to allow for more devices
FLIR_MAX_DEVS=6

###############################################################################
#### Dynamic Configuration ####################################################
#### DO NOT TOUCH! ############################################################
###############################################################################
