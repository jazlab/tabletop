#!/usr/bin/env bash

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../setup.bash

set -e

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    -y|--yes)
      skip_confirmation=true
      ;;
    *)
      print_error "Unknown argument: $1"
      print_error "Usage: $0 [-y|--yes]"
      exit 1
      ;;
  esac
  shift
done

# Get the size of the bags directory
if [ -d "$TABLETOP_BAG_DIR" ]; then
    dir_size=$(du -sh "$TABLETOP_BAG_DIR" | cut -f1)
    print_status "Bags directory size: $dir_size"

    # Count number of files/directories in bags_dir
    item_count=$(ls -1 "$TABLETOP_BAG_DIR" | wc -l)
    print_status "Number of items in bags directory: $item_count"
else
    print_status "Bags directory does not exist: $TABLETOP_BAG_DIR"
    exit 1
fi

# Ask for confirmation before deletion
if [ "$skip_confirmation" = "false" ]; then
    read -p "Do you want to proceed with deleting all bag files in $TABLETOP_BAG_DIR? (y/n): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        print_status "Operation cancelled"
        exit 0
    fi
fi

# Remove all bag files in the bags directory
print_status "Removing all bag files in $TABLETOP_BAG_DIR"
rm -rf $TABLETOP_BAG_DIR/*
print_status "Cleanup complete"
