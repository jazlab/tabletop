#!/usr/bin/env bash
# Generate and validate .env file from .env.example with device auto-detection
# Usage: tt-env-gen [-c|--clean]
# Wraps: dotenv (via embedded helper functions)
# Runs on: host
# Environment: TABLETOP_DIR
# Logic: Detects FLIR cameras via udev symlinks, NVIDIA GPU/CUDA, PulseAudio socket; validates required vars

QUOTE_STYLE=never

set -eo pipefail

bin_dir=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
source "$bin_dir/../../setup.bash"
source "$bin_dir/../utils.sh"

builtin cd "$TABLETOP_DIR"

# Get value of key from environment file and error if not set
dotenv_get_required() {
    if [[ $# == 1 ]]; then
        local file=.env
    elif [[ $# == 2 ]]; then
        local file=$1
        shift
    else
        print_error "Usage: dotenv_get_required [file] KEY"
        return 1
    fi

    declare -n value=$1
    value=$(dotenv --file "$file" get "$1" || true)

    if [[ -z "$value" ]]; then
        print_error "Required key '$1' not set or empty in $file"
        return 1
    fi
}

dotenv_get_optional() {
    if [[ $# == 1 ]]; then
        local file=.env
    elif [[ $# == 2 ]]; then
        local file=$1
        shift
    else
        print_error "Usage: dotenv_get_required [file] KEY"
        return 1
    fi

    declare -n value=$1
    value=$(dotenv --file "$file" get "$1" || true)
}

# Set key to value in environment file
dotenv_set() {
    if [[ $# == 2 ]]; then
        local file=.env
    elif [[ $# == 3 ]]; then
        local file=$1
        shift
    else
        print_error "Usage: dotenv_set [file] KEY VALUE"
        return 1
    fi

    local key=$1
    local value=$2

    dotenv --file $file --quote $QUOTE_STYLE set -- "$key" "$value"
}


# Parse args
while [[ $# -gt 0 ]]; do
    case $1 in
        -c|--clean)
            clean=true
            ;;
        -h|--help)
            cat <<EOF
Usage: $0 [-c|--clean]

Generate and validate the .env file from .env.example with auto-detection of
host hardware (FLIR cameras, NVIDIA GPU, PulseAudio socket).

Options:
  -c, --clean   Remove the existing .env file and regenerate from .env.example
  -h, --help    Show this help message and exit

Environment variables set:
  HOST_UID / HOST_GID          Current user's UID/GID
  COMMANDER_RUNTIME            'nvidia' or 'runc' (based on GPU detection)
  UV_EXTRA                     uv dependency extras (cpu or cu<CUDA_VERSION>)
  FLIR_DEV_0 ... FLIR_DEV_N   Resolved paths to detected FLIR camera devices
  PULSE_SERVER_MNT / PULSE_COOKIE_MNT   PulseAudio socket and cookie mounts
  ROS_BAG_DIR_MNT              ROS bag directory mount (or /dev/null if unset)
EOF
            exit 0
            ;;
        *)
            print_error "Unkown argument: $1"
            echo "Usage: $0 [-c|--clean]"
            exit 1
            ;;
    esac
    shift
done

# Create .env file if it does not exist
if [[ $clean || ! -s .env ]]; then
    rm -f .env
    cp .env.example .env
fi

# Verify that all required variables are set and non-empty
dotenv_get_required NOVNC_DISPLAY
dotenv_get_required NOVNC_WIDTH
dotenv_get_required NOVNC_HEIGHT
dotenv_get_required NOVNC_PORT
dotenv_get_required CUDA_VERSION
dotenv_get_required BIND_CONSISTENCY
dotenv_get_required TEENSY_DEV
dotenv_get_required FLIR_MAX_DEVS

# Get optional variables (may be unset or empty)
dotenv_get_optional ROS_BAG_DIR_HOST

# Set host uid and gid
dotenv_set HOST_UID "$(id -u)"
dotenv_set HOST_GID "$(id -g)"

# Set the ROS bag directory mount point (or /dev/null if not configured)
if [[ -z "$ROS_BAG_DIR_HOST" ]]; then
    dotenv_set ROS_BAG_DIR_MNT /dev/null:/dev/null
    dotenv_set ROS_BAG_DIR_CONTAINER ""
else
    dotenv_set ROS_BAG_DIR_MNT "$ROS_BAG_DIR_HOST:/bags"
    dotenv_set ROS_BAG_DIR_CONTAINER /bags
fi

# Detect NVIDIA GPU and set runtime/CUDA configuration
if command -v nvidia-smi >/dev/null 2>&1; then
    dotenv_set COMMANDER_RUNTIME nvidia
    dotenv_set UV_EXTRA "--extra cu$CUDA_VERSION"
    dotenv_set NVIDIA_VISIBLE_DEVICES all
    dotenv_set NVIDIA_DRIVER_CAPABILITIES all
    # export INSTALL_CUDA=true # Used for building isaac cumotion library, if applicable
else
    dotenv_set COMMANDER_RUNTIME runc
    dotenv_set UV_EXTRA "--extra cpu"
    dotenv_set NVIDIA_VISIBLE_DEVICES ""
    dotenv_set NVIDIA_DRIVER_CAPABILITIES ""
    # export INSTALL_CUDA=true # Used for building isaac cumotion library, if applicable
fi

# Auto-detect FLIR cameras via /dev/flir symlinks created by udev rules
# Loops through all symlinks in /dev/flir, resolves to actual device paths,
# and sets FLIR_DEV_0, FLIR_DEV_1, ... for each found camera (up to FLIR_MAX_DEVS limit)
i=0
if [ -d /dev/flir ]; then
    while IFS= read -r -d '' LINK; do
        if [ -L "$LINK" ]; then
            TARGET=$(readlink -f "$LINK" 2>/dev/null)
            if [ -n "$TARGET" ]; then
                dotenv_set "FLIR_DEV_$i" "$TARGET"
                (( i+=1 ))
            fi
        fi
    done < <(find /dev/flir -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
fi

# Check if the number of detected FLIR devices exceeds the configured maximum
# If so, the user must increase FLIR_MAX_DEVS in .env and add device entries in compose.yaml
if (( i > FLIR_MAX_DEVS )); then
    print_error "You have more cameras connected than FLIR_MAX_DEVS"
    print_error "To remedy, increase the number of FLIR_DEV_* devices in the compose.yaml file"
    print_error "Then, increase FLIR_MAX_DEVS your .env file"
    exit 1
fi

# Set remaining FLIR device slots to /dev/null (no-op mounts)
while (( i < FLIR_MAX_DEVS )); do
    dotenv_set "FLIR_DEV_$i" /dev/null
    (( i+=1 ))
done


# Set Teensy device path if available
# if [ -e /dev/ttyACM0 ]; then
#     dotenv_set TEENSY_DEV /dev/ttyACM0
# else
#     dotenv_set TEENSY_DEV /dev/null
# fi

# Auto-detect PulseAudio socket for audio passthrough to containers
# Checks pactl first, then falls back to XDG_RUNTIME_DIR if available
if command -v pactl >/dev/null 2>&1; then
    PULSE_SERVER_HOST=$(pactl --format=json info | jq -r '.server_string')
    if [[ ! -S "$PULSE_SERVER_HOST" ]]; then
        unset PULSE_SERVER_HOST
    fi
elif [ -S "$XDG_RUNTIME_DIR/pulse/native" ]; then
    PULSE_SERVER_HOST="$XDG_RUNTIME_DIR/pulse/native"
fi

# Mount PulseAudio socket if found, otherwise use /dev/null
if [[ -n "$PULSE_SERVER_HOST" && -f "$HOME/.config/pulse/cookie" ]]; then
    dotenv_set PULSE_SERVER_MNT "$PULSE_SERVER_HOST:/tmp/pulseaudio.socket"
    dotenv_set PULSE_COOKIE_MNT "$HOME/.config/pulse/cookie:/tmp/pulseaudio.cookie"
    dotenv_set PULSE_SERVER_CONTAINER unix:/tmp/pulseaudio.socket
    dotenv_set PULSE_COOKIE_CONTAINER /tmp/pulseaudio.cookie
else
    dotenv_set PULSE_SERVER_MNT /dev/null:/dev/null
    dotenv_set PULSE_COOKIE_MNT /dev/null:/dev/null
    dotenv_set PULSE_SERVER_CONTAINER ""
    dotenv_set PULSE_COOKIE_CONTAINER ""
fi
