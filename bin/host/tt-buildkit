#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

cd $TABLETOP_DIR
source docker/env.bash

case $1 in
    create)
        docker buildx create --name $BUILDX_BUILDER --buildkitd-config docker/buildkitd.toml --driver docker-container --driver-opt default-load=true
        ;;
    rm)
        shift
        docker buildx rm $@
        ;;
    *)
        print_error "Unknown command $1"
        echo "Usage: $0 create|rm [options]"
        ;;
esac
