#!/usr/bin/env bash
# Launch ROS 2 nodes/tasks from the host (delegates to container tt-launch)
# Usage: tt-launch [<launch_type>] [<launch_options>...]
# Wraps: tt-compose run --rm commander tt-launch
# Runs on: host
# Environment: TABLETOP_DIR
# Notes: Supported launch_types: commander, rig, flir, tasks, rviz, moveit, etc. (see container/tt-launch)

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash

exec tt-compose run --rm commander tt-launch "$@"
