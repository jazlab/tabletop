#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

cd $TABLETOP_DIR

# Reset bluetooth module
tt-bluetooth-reset

while true; do
    docker compose up --force-recreate flic
    # Capture the output of the previous command
    output=$(docker compose logs flic 2>&1)
    if [[ "$output" != *"DISCONNECTED"* ]]; then
        print_status "Container stopped, exiting..."
        docker compose down flic
        break
    fi
    print_status "Client disconnected, restarting rig..."
    sleep 2
done
