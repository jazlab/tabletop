#!/usr/bin/env bash
# Build TableTop components from the host
# Usage: tt-build <colcon|microros|foxglove|all> [options...]  — thin host wrapper; see bin/container/tt-build for the full option list
# Wraps: tt-compose run --rm builder tt-build
# Runs on: host
# Environment: TABLETOP_DIR
# Notes: Uses the privileged `builder` service (/dev + platformio-core mounts) so
#        the same wrapper can build the colcon workspace, the Foxglove plugin,
#        and the Teensy/Flic firmware.

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash

exec tt-compose run --rm builder tt-build "$@"
