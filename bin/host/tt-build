#!/usr/bin/env bash
# Build TableTop components from the host
# Usage: tt-build <colcon|microros|foxglove> [options...]  — thin host wrapper; see bin/container/tt-build for the full option list
# Wraps: docker compose run --rm builder tt-build
# Runs on: host
# Environment: TABLETOP_DIR
# Notes: Uses the privileged `builder` service (/dev + platformio-core mounts) so
#        the same wrapper can build the colcon workspace, the Foxglove plugin,
#        and the Teensy firmware.

set -eo pipefail

bin_dir=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
source "$bin_dir/../../setup.bash"

if [[ "${1-}" == "-h" || "${1-}" == "--help" ]]; then
    cat <<EOF
Usage: $0 <component> [options...]

Host wrapper: runs tt-build inside the privileged 'builder' container.
All arguments are forwarded verbatim to the container's tt-build.

Components:
  colcon     Build the ROS 2 workspace with colcon
  microros   Build/upload the Teensy micro-controller firmware (PlatformIO)
  foxglove   Package the Foxglove MoveIt message converter plugin (.foxe)

Run '$0 <component> --help' for component-specific options.

  -h, --help   Show this help message and exit
EOF
    exit 0
fi

builtin cd "$TABLETOP_DIR"

# Regenerate .env and call `docker compose` directly (rather than via tt-compose)
# so this wrapper does not depend on tt-compose, which may change or be replaced.
tt-env-gen 1>/dev/null

exec docker compose run --rm builder tt-build "$@"
