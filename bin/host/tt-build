#!/usr/bin/env bash
# Build the ROS 2 workspace from host
# Usage: tt-build [--build-debug] [-c|--clean-tabletop] [--clean-all] [-w|--workers <num>] [--clang] [--linker <linker>] [-p|--packages <name>...] [--all] [--only-modules]
# Wraps: tt-compose run --rm ros-base tt-build
# Runs on: host
# Environment: TABLETOP_DIR

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash

exec tt-compose run --rm ros-base tt-build "$@"
