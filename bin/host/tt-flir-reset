#!/usr/bin/env bash
# Factory reset FLIR cameras and reinitialize their udev symlinks
# Usage: tt-flir-reset
# Wraps: docker compose, tt-env-gen, udevadm, tt-launch
# Runs on: host
# Environment: TABLETOP_DIR
# Logic: Stops flir container, resets udev, factory-resets cameras, regenerates device paths, restarts container

set -eo pipefail

bin_dir=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
source "$bin_dir/../../setup.bash"
source "$bin_dir/../utils.sh"

if [[ "${1-}" == "-h" || "${1-}" == "--help" ]]; then
    cat <<EOF
Usage: $0

Factory reset FLIR cameras and reinitialize their udev symlinks.

Steps performed:
  1. Stop the running 'flir' container (if any)
  2. Reload udev rules and trigger device re-enumeration
  3. Regenerate .env with updated FLIR device paths
  4. Run factory reset on cameras via 'tt-launch flir_no_sync factory_reset:=true'
  5. Reload udev rules again
  6. Regenerate .env once more
  7. Restart the 'flir' container

  -h, --help   Show this help message and exit

Note: The factory reset step requires manual Ctrl+C when complete (see TODO in script).
EOF
    exit 0
fi

builtin cd "$TABLETOP_DIR"
export COMPOSE_REMOVE_ORPHANS=true

# Regenerate .env and call `docker compose` directly (rather than via tt-compose)
# so this wrapper does not depend on tt-compose, which may change or be replaced.
tt-env-gen 1>/dev/null

# Bring down flir container if running
print_status "Bringing down flir container (if running)"
docker compose down flir

# Reload and trigger udev rules to refresh device state
print_status "Reloading udev rules"
sudo udevadm control --reload
sudo udevadm trigger

sleep 2

# Regenerate env files to detect updated Flir camera paths
print_status "Regenerating .env file to update Flir camera paths"
tt-env-gen

# Run factory reset on cameras
# TODO: Fix this
print_status "Factory resetting Flir cameras"
print_warning "You'll have to ctrl+c when it's done (TODO)"
echo
sleep 1
docker compose run --rm flir tt-launch flir_no_sync factory_reset:=true || true

# Reload and trigger udev rules again to pick up reinitialized cameras
print_status "Reloading udev rules again"
sudo udevadm control --reload
sudo udevadm trigger

sleep 2

# Regenerate env files with updated device paths
print_status "Regenerating .env file once more"
tt-env-gen

# Start flir container again
print_status "Starting flir container again"
print_status "Check logs using 'tt-compose logs flir' to ensure everything is working"
docker compose up flir
