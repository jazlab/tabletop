#!/usr/bin/env bash
# Attach an interactive shell to a dev or custom container
# Usage: tt-dev-attach [<service_name>] (default: dev)
# Wraps: docker compose exec and devcontainer up
# Runs on: host
# Environment: TABLETOP_DIR
# Logic: Starts the specified container if not running, then attaches to its shell

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

builtin cd $TABLETOP_DIR

if [[ $# > 1 ]]; then
    print_error "Usage: $0 [<service_name> (default: dev)]"
    exit 1
fi

SERVICE="${1:-dev}"

export COMPOSE_BAKE=true
export COMPOSE_REMOVE_ORPHANS=true

# Check if the specified container is already running; if not, start it
if [[ ! "$(docker compose ps -q --status=running $SERVICE)" ]]; then
    if [[ "$SERVICE" = dev ]]; then
        devcontainer up
    else
        docker compose up -d $SERVICE
    fi
fi

exec docker compose exec "$SERVICE" /entrypoint.sh bash
