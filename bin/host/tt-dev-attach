#!/usr/bin/env bash

set -eo pipefail

if [[ $# -gt 1 ]]; then
    print_error "Usage: $0 [<service_name> (default 'dev')"
    exit 1
fi

SERVICE=${1:-dev}

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash

cd $TABLETOP_DIR
source docker/env.bash

# Check if dev container is already running
if [[ ! $(docker compose ps -q --status=running $SERVICE) ]]; then
    docker compose up --force-recreate -d $SERVICE
fi

CONTAINER_ID=$(docker compose ps -q $SERVICE)
if [[ $TERM = *kitty* ]]; then
    CMD="kitten run-shell --shell /bin/bash --shell-integration no-cursor"
else
    CMD=bash
fi

docker exec -it $CONTAINER_ID $CMD
