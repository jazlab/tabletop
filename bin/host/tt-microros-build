#!/usr/bin/env bash
# Build and optionally upload MicroROS firmware from host
# Usage: tt-microros-build [-t|--target teensy|flic_micro|all] [--clean] [--no-upload] [--compiledb]
# Wraps: tt-compose run --rm microros-builder tt-microros-build
# Runs on: host
# Environment: TABLETOP_DIR

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash

tt-compose run --rm microros-builder tt-microros-build "$@"
