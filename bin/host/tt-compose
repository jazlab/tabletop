#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

builtin cd $TABLETOP_DIR

tt-env-gen 1>/dev/null

export COMPOSE_BAKE=true
export COMPOSE_REMOVE_ORPHANS=true

ps_format="table {{.Name}}\
\t{{truncate .Image 15}}\
\t{{.Command}}\
\t{{.Service}}\
\t{{.Status}}"

ARGS=()
up=false
bluetooth=false
while [[ $# -gt 0 ]]; do
    ARGS+=("$1")
    case $1 in
        ps)
            ARGS+=("--format" "$ps_format")
            ARGS+=("--all")
            ;;
        up)
            up=true
            ;;
        *flic-sim)
            ;;
        *flic|*flicd|*real)
            bluetooth=true
            ;;
    esac
    shift
done

set -- "${ARGS[@]}"

print_status "docker compose $@"
echo

if [[ "$up" == "true" && "$bluetooth" == "true" ]]; then
    sudo modprobe -r btusb
    sudo modprobe btusb
fi
exec docker compose "$@"
