#!/usr/bin/env bash
# Wrapper for docker compose with TableTop environment generation
# Usage: tt-compose [SUBCOMMAND] [OPTIONS...]
# Wraps: docker compose (with automatic tt-env-gen and custom formatting for ps)
# Runs on: host
# Environment: TABLETOP_DIR
# Side effects: Calls tt-env-gen before executing docker compose; enriches ps output with custom format

set -eo pipefail

bin_dir=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
source "$bin_dir/../../setup.bash"
source "$bin_dir/../utils.sh"

if [[ "${1-}" == "-h" || "${1-}" == "--help" ]]; then
    cat <<EOF
Usage: $0 [SUBCOMMAND] [OPTIONS...]

Wrapper for 'docker compose' that auto-generates .env before each invocation
and enriches the 'ps' subcommand output with a custom column format.

All subcommands and options are forwarded to docker compose.

Common subcommands:
  up      Start services (use --profile=sim or --profile=real)
  down    Stop and remove containers
  ps      List containers (adds name/image/command/service/status columns)
  logs    View output from containers
  pull    Pull service images
  run     Run a one-off command in a service container

Profiles:
  sim     Simulation stack (mock hardware)
  real    Real hardware stack (includes FLIR cameras)
  *       All services (useful with pull)

  -h, --help   Show this help message and exit

Run 'docker compose --help' for the full docker compose option list.
EOF
    exit 0
fi

builtin cd "$TABLETOP_DIR"

tt-env-gen 1>/dev/null

export COMPOSE_REMOVE_ORPHANS=true

# Customize output format for 'ps' subcommand (name, image, command, service, status)
ps_format="table {{.Name}}\
\t{{truncate .Image 15}}\
\t{{.Command}}\
\t{{.Service}}\
\t{{.Status}}"

args=()
while [[ $# -gt 0 ]]; do
    args+=("$1")
    case $1 in
        ps)
            args+=("--format" "$ps_format")
            args+=("--all")
            ;;
    esac
    shift
done

set -- "${args[@]}"

print_status "docker compose $@"
echo

exec docker compose "$@"
