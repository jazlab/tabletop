#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

builtin cd $TABLETOP_DIR
source docker/env.bash

ARGS=("$@")

for (( i=0; i<$#; i++ )); do
    case ${ARGS[$i]} in
        down)
            POST_CMD_ARGS=("--volumes")
            break
            ;;
        # build)
        #     POST_CMD_ARGS=("--pull")
        #     break
        #     ;;
        # up)
        #     POST_CMD_ARGS=("--force-recreate")
        #     break
        #     ;;
    esac
done

set -- "${ARGS[@]:0:$i}" "${PRE_CMD_ARGS[@]}" "${ARGS[$i]}" "${POST_CMD_ARGS[@]}" "${ARGS[@]:$((i+1))}"

print_status "docker compose $@"
echo

docker compose $@
