#!/usr/bin/env bash
# Wrapper for docker compose with TableTop environment generation
# Usage: tt-compose [SUBCOMMAND] [OPTIONS...]
# Wraps: docker compose (with automatic tt-env-gen and custom formatting for ps)
# Runs on: host
# Environment: TABLETOP_DIR
# Side effects: Calls tt-env-gen before executing docker compose; enriches ps output with custom format

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

builtin cd $TABLETOP_DIR

tt-env-gen 1>/dev/null

export COMPOSE_REMOVE_ORPHANS=true

# Customize output format for 'ps' subcommand (name, image, command, service, status)
ps_format="table {{.Name}}\
\t{{truncate .Image 15}}\
\t{{.Command}}\
\t{{.Service}}\
\t{{.Status}}"

args=()
while [[ $# -gt 0 ]]; do
    args+=("$1")
    case $1 in
        ps)
            args+=("--format" "$ps_format")
            args+=("--all")
            ;;
    esac
    shift
done

set -- "${args[@]}"

print_status "docker compose $@"
echo

exec docker compose "$@"
