#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

builtin cd $TABLETOP_DIR

export COMPOSE_BAKE=true
export COMPOSE_REMOVE_ORPHANS=true

ARGS=()
# export COMPOSE_PROFILES="*"
build=false
while [[ $# -gt 0 ]]; do
    case $1 in
        build)
            ARGS+=("$1")
            export COMPOSE_PROFILES="*"
            build=true
            # ARGS+=("--builder" "tabletop_builder")
            # export BUILDKIT_PROGRESS=plain
            ;;
        # up)
        #     unset COMPOSE_PROFILES
        #     ;;
        ps)
            ARGS+=("$1")
            ARGS+=("--format" "table {{.Name}}\t{{truncate .Image 15}}\t{{.Command}}\t{{.Service}}\t{{.Status}}")
            ARGS+=("--all")
            ;;
        down)
            ARGS+=("$1")
            ARGS+=("--volumes")
            ;;
        *)
            ARGS+=("$1")
            ;;
    esac
    shift
done

set -- "${ARGS[@]}"

print_status "docker compose $@"
echo

if [[ "$build" = true ]]; then
    docker compose "$@"
    docker compose run --rm ros-base bash -c "tt-build --only-modules && tt-build"
else
    exec docker compose "$@"
fi
