#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

builtin cd $TABLETOP_DIR

tt-env-gen 1>/dev/null

export COMPOSE_BAKE=true
export COMPOSE_REMOVE_ORPHANS=true
# export COMPOSE_PROFILES="*"

ps_format="table {{.Name}}\
\t{{truncate .Image 15}}\
\t{{.Command}}\
\t{{.Service}}\
\t{{.Status}}"

ARGS=()
build=false
while [[ $# -gt 0 ]]; do
    case $1 in
        build)
            build=true
            ARGS+=("$@")
            break
            # ARGS+=("--builder" "tabletop_builder")
            # export BUILDKIT_PROGRESS=plain
            ;;
        ps)
            ARGS+=("$1")
            shift
            ARGS+=("--format" "$ps_format")
            ARGS+=("--all")
            ARGS+=("$@")
            break
            ;;
        # down)
        #     ARGS+=("$1")
        #     # ARGS+=("--volumes")
        #     ;;
        *)
            ARGS+=("$1")
            ;;
    esac
    shift
done

set -- "${ARGS[@]}"

print_status "docker compose $@"
echo

if [[ "$build" == "true" ]]; then
    export COMPOSE_PROFILES="*"
    docker compose down --volumes
    docker compose "$@"
    exec docker compose run --rm ros-base tt-build --all
else
    exec docker compose "$@"
fi
