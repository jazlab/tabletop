#!/usr/bin/env bash


set -e

# PlatformIO
sudo curl -fsSL -o /etc/udev/rules.d/99-platformio-udev.rules https://raw.githubusercontent.com/platformio/platformio-core/develop/platformio/assets/system/99-platformio-udev.rules

# Flir Cameras
FLIR_UDEV_FILE=/etc/udev/rules.d/40-flir-udev.rules
sudo tee $FLIR_UDEV_FILE > /dev/null <<EOF
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e10", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="1724", MODE="0666"
EOF

sudo udevadm control --reload
sudo udevadm trigger
