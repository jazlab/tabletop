#!/usr/bin/env bash

set -e

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../setup.bash

print_usage() {
    print_error "Usage: $0 [--debug] [--clean] [--clean-all] [-w|--workers <num_workers>] [--clang] [--linker <linker>] [-p|--packages <package_name>...] [--all] [--only-deps]"
}

pushd $COLCON_WS

# Parse arguments
debug=false
clean=false
clean_all=false
workers=
packages=()
linker=mold
all=false
clang=false
only_deps=false
while [[ $# -gt 0 ]]; do
    case $1 in
        --debug)
            debug=true
            ;;
        --clean)
            clean=true
            ;;
        --clean-all)
            clean_all=true
            ;;
        -w|--workers)
            workers=$2
            shift
            ;;
        --clang)
            clang=true
            ;;
        --linker)
            linker=$2
            shift
            ;;
        -p|--packages)
            if [[ $# -le 1  || $2 == -* ]]; then
                print_error "No packages provided"
                print_usage
                exit 1
            fi
            while [[ $# -gt 1 && $2 != -* ]]; do
                packages+=($2)
                shift
            done
            ;;
        -a|--all)
            all=true
            ;;
        --only-deps)
            only_deps=true
            ;;
        *)
            print_error "Unknown argument $1"
            print_usage
            exit 1
            ;;
    esac
    shift
done

if [ "$all" = "true" ]; then
    if [ ${#packages[@]} -gt 0 ]; then
        print_error "Cannot use --all with -p|--packages"
        print_usage
        exit 1
    fi
    package_selection=
else
    if [ ${#packages[@]} -eq 0 ]; then
        packages=(tabletop)
    fi
    package_selection="--packages-up-to ${packages[@]}"
fi

# Clean workspace
if [ "$clean_all" = "true" ]; then
    tt-clean-ws --all --log
elif [ "$clean" = "true" ]; then
    tt-clean-ws
fi

# Upgrade apt packages
print_status "Upgrading apt packages"
sudo apt update
sudo apt upgrade -y
sudo apt dist-upgrade -y
rosdep update -q

# Install Python dependencies
print_status "Installing Python dependencies using uv"
uv sync $TT_UV_EXTRA

# Remove any existing MoveIt2 debian packages
print_status "Removing any existing MoveIt2 debian packages"
sudo apt remove -y ros-${ROS_DISTRO}-moveit* || true

# Source ROS environment again after rosdep update
source $TABLETOP_DIR/setup.bash

# Install ROS 2 build dependencies
dependency_types="-t buildtool_export -t build -t build_export -t buildtool"
if [ "$only_deps" = "true" ]; then
    print_status "Installing ROS 2 dependencies"
    dependency_types="$dependency_types -t exec"
else
    print_status "Installing ROS 2 build dependencies"
fi

rosdep install --from-paths src --ignore-src --rosdistro ${ROS_DISTRO} $dependency_types -y

if [ "$only_deps" = "true" ]; then
    print_status "Successfully installed dependencies, skipping build and exiting"
    exit 0
fi

# Set CMake arguments
cmake_args=("-DUAGENT_BUILD_EXECUTABLE=OFF" "-DUAGENT_P2P_PROFILE=OFF")

# Set Mixins
mixins=()
if [ "$debug" = "true" ]; then
    mixins+=("debug")
else
    mixins+=("release")
fi

if [ "$clang" = "true" ]; then
    mixins+=("clang")
fi
mixins+=("compile-commands" "build-testing-off" "ccache" "$linker")

# Build ROS 2 packages
if [ -n "$workers" ]; then
    export MAKEFLAGS="-j$workers"
    parallel_workers="--parallel-workers $workers"
fi
command="python3 -m colcon build \
--symlink-install \
--event-handlers console_cohesion+ \
--cmake-args "${cmake_args[@]}" \
--mixin "${mixins[@]}" \
$parallel_workers \
$package_selection"

print_status "Building ROS 2 packages with command: $command"
$command

source install/setup.bash

# Install ROS 2 runtime dependencies
print_status "Installing ROS 2 runtime dependencies"
dependency_types="-t exec"
rosdep install --from-paths src --ignore-src --rosdistro ${ROS_DISTRO} $dependency_types -y

print_status "Successfully built ROS 2 packages!"

popd
