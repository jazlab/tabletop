#!/usr/bin/env bash

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/setup.bash

# Configure git to ignore safe.directory
pushd $TABLETOP_DIR
git config --global --add safe.directory $TABLETOP_DIR
git submodule foreach --recursive 'git config --global --add safe.directory $sm_path'
popd
