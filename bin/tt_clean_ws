#!/usr/bin/env bash

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/setup.bash

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --all)
            all=true
            shift
            ;;
        --micro-ros)
            micro_ros=true
            shift
            ;;
        *)
            echo "Unknown argument: $1"
            echo "Usage: $0 [--all] [--micro-ros]"
            exit 1
            ;;
    esac
done


if [ "$all" = true ]; then
    print_status "Cleaning build, install, and log directories (including moveit)"
    sudo rm -rf $COLCON_WS/build $COLCON_WS/install
else
    print_status "Cleaning build, install, and log directories (except moveit)"
    dirs_to_clean=("tabletop*")
    if [ "$micro_ros" = true ]; then
        dirs_to_clean+=("micro_ros_agent" "micro_ros_msgs" "drive_base_msgs")
    fi
    for dir in "${dirs_to_clean[@]}"; do
        rm -rf $COLCON_WS/install/$dir $COLCON_WS/build/$dir
    done
fi
sudo rm -rf $COLCON_WS/log
