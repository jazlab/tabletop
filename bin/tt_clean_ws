#!/usr/bin/env bash

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/setup.bash

# Parse arguments
all=false
micro_ros=false
log=false
while [[ $# -gt 0 ]]; do
    case $1 in
        --all)
            all=true
            shift
            ;;
        --micro-ros)
            micro_ros=true
            shift
            ;;
        --log)
            log=true
            shift
            ;;
        *)
            print_error "Unknown argument: $1"
            print_error "Usage: $0 [--all] [--micro-ros] [--log]"
            exit 1
            ;;
    esac
done


if [[ $all = true ]]; then
    print_status "Removing $COLCON_WS/build and $COLCON_WS/install (including moveit)"
    sudo rm -rf $COLCON_WS/build $COLCON_WS/install
else
    dirs_to_clean=("tabletop*")
    if [[ $micro_ros = true ]]; then
        dirs_to_clean+=("micro_ros_agent" "micro_ros_msgs")
    fi
    print_status "Removing ${dirs_to_clean[@]} in $COLCON_WS/install and $COLCON_WS/build"
    for dir in "${dirs_to_clean[@]}"; do
        rm -rf $COLCON_WS/install/$dir $COLCON_WS/build/$dir
    done
fi

if [[ "$log" = true ]]; then
    print_status "Removing $COLCON_WS/log"
    sudo rm -rf $COLCON_WS/log
fi
