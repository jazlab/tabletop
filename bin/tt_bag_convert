#!/usr/bin/env bash

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/setup.bash

for dir in "$TABLETOP_BAG_DIR"/*/; do
    if [ -d "$dir" ]; then
        echo "Converting bag in: $dir"
        pushd "$dir" > /dev/null
        ros2 bag convert -i . -o $TABLETOP_DIR/ros/tabletop_server/config/rosbag_sqlite3.yaml
        popd > /dev/null
    fi
done
