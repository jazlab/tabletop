#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

cd $COLCON_WS

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --all)
            all=true
            shift
            ;;
        --micro-ros)
            micro_ros=true
            shift
            ;;
        *)
            print_error "Unknown argument: $1"
            print_error "Usage: $0 [--all] [--micro-ros]"
            exit 1
            ;;
    esac
done

if [[ $all = true ]]; then
    to_clean=("build" "install" "log/colcon")
else
    sub_to_clean=("tabletop*")
    if [[ $micro_ros = true ]]; then
        sub_to_clean+=("micro_ros*")
    fi
    for dir in "${sub_to_clean[@]}"; do
        to_clean+=("install/$dir" "build/$dir")
    done
fi

print_status "Removing ${to_clean[@]}"
rm -rf ${to_clean[@]}
