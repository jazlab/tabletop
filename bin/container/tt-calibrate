#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <calibration_filename.yaml>"
    exit 1
fi

calib_file="$1"
config_dir=$(colcon_cd tabletop_description)/config
target_file="$config_dir/$calib_file"

if [[ -f "$target_file" ]]; then
    print_warning "File '$target_file' already exists."
    read -p "Overwrite? [y/N]: " confirm
    case "$confirm" in
        [yY][eE][sS]|[yY]) ;;
        *) echo "Aborted."; exit 1 ;;
    esac
fi


ros2 launch ur_calibration calibration_correction.launch.py robot_ip:=$ROBOT_IP target_filename:=$target_file
