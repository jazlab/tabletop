#!/usr/bin/env bash
# Build the ROS 2 workspace with colcon (runs in container)
# Usage: tt-build [--build-debug] [-c|--clean-tabletop] [--clean-all] [-w|--workers <num>] [--clang] [--linker <linker>] [-p|--packages <name>...] [--all] [--only-modules] [--foxglove]
# Runs on: container
# Environment: TABLETOP_DIR, COLCON_WS, UV_PROJECT_ENVIRONMENT
# Logic: Parses args to select package scope (tabletop/all/modules/specific), configures CMake mixins (ccache/linker/compiler), runs colcon build

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

print_usage() {
    echo "Usage: $0 [--build-debug] [-c|--clean-tabletop] [--clean-all] [-w|--workers <num_workers>] [--clang] [--linker <linker>] [-p|--packages <package_name>...] [--all] [--only-modules] [--foxglove]"
}

builtin cd $COLCON_WS

# Parse arguments
build_debug=false
clean_tabletop=false
clean_cmake=
clean_all=false
all=false
packages_up_to=()
only_modules=false
workers=
linker=mold
clang=false
foxglove=false
verbose=false
while [[ $# -gt 0 ]]; do
    case $1 in
        -a|--all)
            all=true
            ;;
        -p|--packages-up-to)
            while [[ $# -gt 1 && $2 != -* ]]; do
                packages_up_to+=($2)
                shift
            done
            if [[ ${#packages_up_to[@]} -eq 0 ]]; then
                print_error "No packages provided with -p|--packages-up-to"
                print_usage
                exit 1
            fi
            ;;
        -m|--only-modules)
            only_modules=true
            ;;
        -c|--clean-tabletop)
            clean_tabletop=true
            ;;
        --clean-cmake)
            clean_cmake="--cmake-clean-cache"
            ;;
        --clean-all)
            clean_all=true
            ;;
        --build-debug)
            build_debug=true
            ;;
        -w|--workers)
            if [[ $# -le 1  || $2 == -* ]]; then
                print_error "No workers provided with --workers"
                print_usage
                exit 1
            fi
            workers=$2
            shift
            ;;
        --clang)
            clang=true
            ;;
        --linker)
            if [[ $# -le 1  || $2 == -* ]]; then
                print_error "No linker provided with --linker"
                print_usage
                exit 1
            fi
            linker=$2
            shift
            ;;
        --foxglove)
            foxglove=true
            ;;
        -v|--verbose)
            verbose=true
            ;;
        *)
            print_error "Unknown argument $1"
            print_usage
            exit 1
            ;;
    esac
    shift
done

# Select which packages to build based on flags (mutually exclusive options)
base_paths="src/ros"
package_selection=
if [[ $all = true ]]; then
    # Build all packages in src/ros (both tabletop and modules)
    if [[ ${#packages_up_to[@]} -gt 0  || $only_modules = true ]]; then
        print_error "Cannot use --all with -p|--packages or -d|--only-modules"
        print_usage
        exit 1
    fi
elif [[ $only_modules = true ]]; then
    # Build only external dependencies in src/ros/modules (moveit2, etc.)
    if [[ ${#packages_up_to[@]} -gt 0 ]]; then
        print_error "Cannot use -p|--packages with -d|--only-modules"
        print_usage
        exit 1
    fi
    base_paths="src/ros/modules"
    # from_paths="--from-paths $base_paths"
elif [[ ${#packages_up_to[@]} -gt 0 ]]; then
    # Build only specified packages and their recursive dependencies
    package_selection="--packages-up-to ${packages_up_to[@]}"
else
    # Default: build only tabletop packages (most common case)
    base_paths="src/ros/tabletop"
    # skip_moveit_apt_removal="--skip-moveit-apt-removal"
fi

# Skip architecture-dependent packages (e.g., x86_64-only)
packages_to_skip=("moveit_ros_tests")
# if [[ $(uname -m) != x86_64 ]]; then
#     packages_to_skip+=("mocap4r2_optitrack_driver")
# fi
packages_skip="--packages-skip ${packages_to_skip[@]}"

# Clean workspace if requested
if [[ "$clean_all" == true ]]; then
    tt-clean --all-colcon
elif [[ "$clean_tabletop" == true ]]; then
    tt-clean --tabletop-colcon
fi

# Install python dependencies with uv (respects UV_EXTRA from environment)
print_status "Installing python dependencies with uv"
uv sync $UV_EXTRA
source "$TABLETOP_DIR/$UV_PROJECT_ENVIRONMENT/bin/activate"

# Build ROS 2 packages with colcon

# Set CMake arguments (disable micro-agent features)
cmake_args=("-DUAGENT_BUILD_EXECUTABLE=OFF" "-DUAGENT_P2P_PROFILE=OFF")

# Build mixins control compilation flags and toolchain (ccache, linker, compiler)
mixins=()
mixins+=("build-testing-off" "ccache" "$linker")

if [[ $all = true ]]; then
    rm -f "$TABLETOP_DIR/build/compile_commands.json"
    mixins+=("compile-commands")
fi

# Select debug or release build
if [[ $build_debug = true ]]; then
    mixins+=("debug")
else
    mixins+=("release")
fi

# Optionally use clang compiler instead of gcc
if [[ $clang = true ]]; then
    mixins+=("clang")
fi

# Set parallel workers if specified
if [[ -n $workers ]]; then
    # export MAKEFLAGS="-j$workers -l1"
    parallel_workers="--parallel-workers $workers"
fi

# Enable verbose event handlers for build output
if [[ $verbose = true ]]; then
    event_handlers="--event-handlers console_cohesion+"
fi

# Build ROS 2 packages
command="colcon --log-base log/colcon build \
--base-paths $base_paths \
$packages_skip \
$packages_skip_regex \
$package_selection \
--cmake-args "${cmake_args[@]}" \
$clean_cmake \
--mixin "${mixins[@]}" \
$parallel_workers \
--symlink-install \
$event_handlers"


print_status "Building ROS 2 packages with command: $command"
$command
print_status "Successfully built ROS 2 packages!"

# Build Foxglove message converters if requested
if [[ "$foxglove" == true ]]; then
    builtin cd "$TABLETOP_DIR/src/ros/modules/foxglove_moveit_msg_converter"
    npm run package
fi
