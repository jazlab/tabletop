#!/usr/bin/env bash
# Build and optionally upload MicroROS firmware for Teensy and Flic Micro devices (runs in container)
# Usage: tt-microros-build [-t|--target teensy|flic_micro|all] [--clean] [--no-upload] [--compiledb]
# Wraps: pio (PlatformIO) commands for building/uploading microcontroller firmware
# Runs on: container
# Environment: TABLETOP_DIR
# Logic: Parses target selection, iterates over project directories, runs pio with retries for uploads

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh


print_usage() {
    echo "Usage: $0 [-t|--target teensy(default)|flic_micro|all] [--clean] [--no-upload] [--compiledb]"
}

# Default: build and upload teensy firmware with 2 retries on failure
target_arg="--target upload"
retries=2
project_dirs=(
    "$TABLETOP_DIR/src/ros/tabletop/tabletop_micro/tabletop_teensy"
)
while [[ $# -gt 0 ]]; do
    case $1 in
        --clean)
            clean=true
            ;;
        --no-upload)
            # Build only (no upload); 1 retry
            unset target_arg
            retries=1
            ;;
        --compiledb)
            # Generate compile_commands.json for IDE integration; 1 retry
            target_arg="--target compiledb"
            retries=1
            ;;
        -t|--target)
            # Select which microcontroller projects to build
            shift
            case $1 in
                teensy)
                    project_dirs=("$TABLETOP_DIR/src/ros/tabletop/tabletop_micro/tabletop_teensy")
                    ;;
                flic_micro)
                    project_dirs=("$TABLETOP_DIR/src/ros/tabletop/tabletop_micro/tabletop_flic_micro")
                    ;;
                all)
                    project_dirs=(
                        "$TABLETOP_DIR/src/ros/tabletop/tabletop_micro/tabletop_teensy"
                        "$TABLETOP_DIR/src/ros/tabletop/tabletop_micro/tabletop_flic_micro"
                    )
                    ;;
                *)
                    print_error "Error: Unknown target '$1'"
                    print_usage
                    exit 1
                    ;;
            esac
            ;;
        *)
            print_error "Error: Unknown argument '$1'"
            print_usage
            exit 1
            ;;
    esac
    shift
done

# Build each selected project with retries on upload failures
for project_dir in "${project_dirs[@]}"; do
    builtin cd $project_dir

    if [[ "$clean" = true ]]; then
        print_status "Cleaning microros build directory"
        # rm -rf .pio
        pio run --target clean_microros
    fi

    print_status "Building MicroROS at $project_dir"
    i=0
    # Retry loop: attempt build/upload up to $retries times on failure
    while (( i < retries )) && ! pio run $target_arg; do
        (( i+=1 ))
        if (( i >= retries )); then
            print_error "Build failed $i times, aborting"
            exit 1
        fi

        if [[ -n $target_arg ]]; then
            print_status "Build failed, retrying..."
            sleep 1
        else
            print_error "Build failed, aborting"
            exit 1
        fi
    done
done
