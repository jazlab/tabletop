#!/usr/bin/env bash

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

print_usage() {
    echo "Usage: $0 [<launch_type>] [<launch_options>...]"
    echo "launch_type can be one of commander, rig, flir, or tasks"
}

EXEC=
RUN=
LAUNCH=
case $1 in
    discovery)
        if [[ -z "$ROS_DISCOVERY_SERVER" ]]; then
            print_warning "ROS_DISCOVERY_SERVER environment variable not set"
            print_warning "Not launching discovery server"
            EXEC="sleep infinity"
            set -- " "
        else
            export ROS_LOG_DIR="$ROS_LOG_DIR/discovery"
            IFS=':' read -ra SERVER <<< "$ROS_DISCOVERY_SERVER"
            if [[ "${#SERVER[@]}" != 2 ]]; then
                print_error "Incorrect ROS_DISCOVERY_SERVER format: $ROS_DISCOVERY_SERVER"
                exit 1
            fi
            EXEC="fastdds discovery --server-id 0 --udp-address ${SERVER[0]} --udp-port ${SERVER[1]}"
        fi
        ;;
    foxglove)
        export ROS_LOG_DIR="$ROS_LOG_DIR/foxglove"
        LAUNCH="foxglove_bridge foxglove_bridge_launch.xml port:=$FOXGLOVE_PORT"
        ;;
    moveit)
        export ROS_LOG_DIR="$ROS_LOG_DIR/moveit"
        LAUNCH="tabletop_moveit_config moveit.launch.py"
        ;;
    rviz)
        export ROS_LOG_DIR="$ROS_LOG_DIR/rviz"
        LAUNCH="tabletop_rig rviz.launch.py"
        ;;
    flir)
        export ROS_LOG_DIR="$ROS_LOG_DIR/flir"
        LAUNCH="tabletop_rig flir.launch.py"
        ;;
    flir_calibrate)
        export ROS_LOG_DIR="$ROS_LOG_DIR/flir_calibrate"
        LAUNCH="tabletop_rig flir_calibrate.launch.py"
        ;;
    ur)
        export ROS_LOG_DIR="$ROS_LOG_DIR/ur"
        LAUNCH="tabletop_rig ur.launch.py"
        ;;
    dual_ur)
        export ROS_LOG_DIR="$ROS_LOG_DIR/dual_ur"
        LAUNCH="tabletop_rig dual_ur.launch.py"
        ;;
    multi_ur)
        export ROS_LOG_DIR="$ROS_LOG_DIR/multi_ur"
        LAUNCH="tabletop_rig multi_ur.launch.py"
        ;;
    optitrack)
        export ROS_LOG_DIR="$ROS_LOG_DIR/optitrack"
        LAUNCH="tabletop_rig optitrack.launch.py"
        ;;
    teensy)
        export ROS_LOG_DIR="$ROS_LOG_DIR/teensy"
        LAUNCH="tabletop_rig teensy.launch.py"
        ;;
    flic)
        export ROS_LOG_DIR="$ROS_LOG_DIR/flic"
        LAUNCH="tabletop_rig flic.launch.py"
        ;;
    eyelink)
        export ROS_LOG_DIR="$ROS_LOG_DIR/eyelink"
        LAUNCH="tabletop_rig eyelink.launch.py"
        ;;
    rig)
        export ROS_LOG_DIR="$ROS_LOG_DIR/rig"
        LAUNCH="tabletop_rig rig.launch.py"
        ;;
    commander)
        export ROS_LOG_DIR="$ROS_LOG_DIR/commander"
        LAUNCH="tabletop_rig commander.launch.py"
        ;;
    task|tasks)
        export ROS_LOG_DIR="$ROS_LOG_DIR/tasks"
        LAUNCH="tabletop_tasks tasks.launch.py"
        ;;
    rosbag)
        export ROS_LOG_DIR="$ROS_LOG_DIR/rosbag"
        LAUNCH="tabletop_rig rosbag.launch.py"
        ;;
    rosbag_convert|rosbag_to_csv)
        export ROS_LOG_DIR="$ROS_LOG_DIR/rosbag_convert"
        RUN="tabletop_rig rosbag_to_csv"
        ;;
    *)
        print_error "launch_type $1 unsupported"
        print_usage
        exit 1
        ;;
esac

shift

if [[ -n "$EXEC" ]]; then
    exec $EXEC "$@"
elif [[ -n "$RUN" ]]; then
    exec ros2 run $RUN "$@"
elif [[ -n "$LAUNCH" ]]; then
    exec ros2 launch $LAUNCH "$@"
else
    print_error "This should never happen"
fi
