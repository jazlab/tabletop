#!/usr/bin/env bash
# Route and launch ROS 2 nodes/services in container (wraps ros2 launch, ros2 run, and raw commands)
# Usage: tt-launch [<launch_type>] [<launch_options>...]
# Runs on: container
# Environment: ROS_LOG_DIR, FOXGLOVE_PORT
# Logic: Case statement routes launch_type to appropriate ros2 launch/run/exec command; sets per-launch log directories

set -eo pipefail

bin_dir=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
source "$bin_dir/../../setup.bash"
source "$bin_dir/../utils.sh"

print_usage() {
    echo "Usage: $0 [<launch_type>] [<launch_options>...]"
    echo "launch_type: commander, rig, tasks, dual_ur, teensy, flic, eyelink, flir_no_sync, flir_synchronized, flir_calibrate, optitrack, rosbag, rosbag_convert, rviz, foxglove, moveit, discovery"
}

# Case statement routes to one of three execution modes: EXEC (raw command), RUN (ros2 run), or LAUNCH (ros2 launch)
EXEC=
RUN=
LAUNCH=
case $1 in
    discovery)
        # FastDDS discovery server (requires ROS_DISCOVERY_SERVER env var formatted as host:port)
        # This feature is deprecated, see ROS2 docs for details if desired
        # https://docs.ros.org/en/jazzy/Tutorials/Advanced/Discovery-Server/Discovery-Server.html
        if [[ -z "$ROS_DISCOVERY_SERVER" ]]; then
            print_warning "ROS_DISCOVERY_SERVER environment variable not set"
            print_warning "Not launching discovery server"
            EXEC="sleep infinity"
            set -- " "
        else
            export ROS_LOG_DIR="$ROS_LOG_DIR/discovery"
            IFS=':' read -ra SERVER <<< "$ROS_DISCOVERY_SERVER"
            if [[ "${#SERVER[@]}" != 2 ]]; then
                print_error "Incorrect ROS_DISCOVERY_SERVER format: $ROS_DISCOVERY_SERVER"
                exit 1
            fi
            EXEC="fastdds discovery --server-id 0 --udp-address ${SERVER[0]} --udp-port ${SERVER[1]}"
        fi
        ;;
    foxglove)
        # Foxglove bridge for visualization
        export ROS_LOG_DIR="$ROS_LOG_DIR/foxglove"
        LAUNCH="foxglove_bridge foxglove_bridge_launch.xml port:=$FOXGLOVE_PORT"
        ;;
    moveit)
        # MoveIt interactive planning (standalone move_group + RViz)
        export ROS_LOG_DIR="$ROS_LOG_DIR/moveit"
        LAUNCH="tabletop_moveit_config moveit.launch.py"
        ;;
    rviz)
        # RViz visualization
        export ROS_LOG_DIR="$ROS_LOG_DIR/rviz"
        LAUNCH="tabletop_rig rviz.launch.py"
        ;;
    flir_no_sync)
        # FLIR camera drivers
        export ROS_LOG_DIR="$ROS_LOG_DIR/flir"
        LAUNCH="tabletop_rig flir.launch.py"
        ;;
    flir_synchronized)
        # FLIR cameras with synchronized acquisition
        export ROS_LOG_DIR="$ROS_LOG_DIR/flir"
        LAUNCH="tabletop_rig flir_synchronized.launch.py"
        ;;
    flir_calibrate)
        # FLIR camera calibration
        export ROS_LOG_DIR="$ROS_LOG_DIR/flir_calibrate"
        LAUNCH="tabletop_rig flir_calibrate.launch.py"
        ;;
    dual_ur)
        # Two UR5e arms driver
        export ROS_LOG_DIR="$ROS_LOG_DIR/dual_ur"
        LAUNCH="tabletop_rig dual_ur.launch.py"
        ;;
    optitrack)
        # OptiTrack motion capture system
        export ROS_LOG_DIR="$ROS_LOG_DIR/optitrack"
        LAUNCH="tabletop_rig optitrack.launch.py"
        ;;
    teensy)
        # Teensy microcontroller (arm locks, safety laser, reward)
        export ROS_LOG_DIR="$ROS_LOG_DIR/teensy"
        LAUNCH="tabletop_rig teensy.launch.py"
        ;;
    flic)
        # Flic button response time measurement (requires elevated capabilities for packet capture)
        # sudo touch /etc/ld.so.conf.d/ros.conf
        # IFS=':' read -ra ADDR <<< "$LD_LIBRARY_PATH"
        # for i in "${ADDR[@]}"; do
        #     sudo echo "$i" >> /etc/ld.so.conf.d/ros.conf
        # done
        sudo setcap 'cap_net_raw,cap_net_admin=+eip' /usr/bin/python3.12
        export ROS_LOG_DIR="$ROS_LOG_DIR/flic"
        LAUNCH="tabletop_rig flic.launch.py"
        ;;
    eyelink)
        # EyeLink eye tracker
        export ROS_LOG_DIR="$ROS_LOG_DIR/eyelink"
        LAUNCH="tabletop_rig eyelink.launch.py"
        ;;
    rig)
        # Full rig (all hardware interfaces)
        export ROS_LOG_DIR="$ROS_LOG_DIR/rig"
        LAUNCH="tabletop_rig rig.launch.py"
        ;;
    commander)
        # Commander orchestrator node (high-level rig control)
        export ROS_LOG_DIR="$ROS_LOG_DIR/commander"
        LAUNCH="tabletop_rig commander.launch.py"
        ;;
    task|tasks)
        # Experiment task nodes
        export ROS_LOG_DIR="$ROS_LOG_DIR/tasks"
        LAUNCH="tabletop_tasks tasks.launch.py"
        ;;
    rosbag)
        # ROS bag recorder
        export ROS_LOG_DIR="$ROS_LOG_DIR/rosbag"
        LAUNCH="tabletop_rig rosbag.launch.py"
        ;;
    rosbag_convert|rosbag_to_csv)
        # Rosbag conversion tool
        export ROS_LOG_DIR="$ROS_LOG_DIR/rosbag_convert"
        RUN="tabletop_rig rosbag_to_csv"
        ;;
    *)
        print_error "launch_type $1 unsupported"
        print_usage
        exit 1
        ;;
esac

shift

# Execute based on which mode was set by the case statement
if [[ -n "$EXEC" ]]; then
    exec $EXEC "$@"
elif [[ -n "$RUN" ]]; then
    exec ros2 run $RUN "$@"
elif [[ -n "$LAUNCH" ]]; then
    exec ros2 launch $LAUNCH "$@"
else
    print_error "This should never happen"
fi
