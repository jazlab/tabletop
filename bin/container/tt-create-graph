#!/usr/bin/env bash
# Generate ROS 2 computation graph visualization (requires running ROS nodes)
# Usage: tt-create-graph [output_file] (default: graph.md in TABLETOP_DIR/docs)
# Wraps: ros2 node list, ros2_graph
# Runs on: container
# Environment: TABLETOP_DIR
# Note: Must be run while ROS 2 nodes are active (after tt-launch)

set -eo pipefail

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

if [[ $# -gt 1 ]]; then
    print_error "Usage: $0 [output_file]"
    print_error "If not provided, the graph will be saved to $TABLETOP_DIR/docs/graph.md"
    exit 1
fi

pushd $TABLETOP_DIR/docs

# List of nodes to exclude from graph (currently empty; examples shown as comments)
nodes_to_ignore=""
# /rosbag2_recorder
# /rviz2
# /forward_position_controller
# /forward_velocity_controller
# /force_mode_controller
# /force_torque_sensor_broadcaster
# /freedrive_mode_controller
# /joint_trajectory_controller
# /passthrough_trajectory_controller"

# Query active ROS nodes and filter out excluded nodes (currently no filtering since nodes_to_ignore is empty)
nodes=$(ros2 node list | grep -vE "$nodes_to_ignore" | tr '\n' ' ')
echo Nodes: $nodes

output_file=${1:-graph.md}
ros2_graph $nodes -o $output_file --styleConfig ros/graph_style.yaml

popd
