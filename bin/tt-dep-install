#!/usr/bin/env bash

set -e

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../setup.bash

print_usage() {
    print_error "Usage: $0 [-t|--type <type>] [--skip-uv] [--skip-apt]"
    print_error "-t|--type can be 'build', 'exec', or 'both (default)'"
    print_error "   If set to 'build', existing moveit apt packages will be removed"
    print_error "--from-paths will set the from paths for the dependency installation (default: src/ros)"
    print_error "--skip-uv will skip the Python dependency installation using uv"
    print_error "--skip-apt will skip the apt package installation"
    print_error "--skip-moveit-apt-removal will skip the removal of existing moveit apt packages if -t|--type is set to 'build'"
}

cd $COLCON_WS

# Parse arguments
type=both
from_paths=()
while [[ $# -gt 0 ]]; do
    case $1 in
        -t|--type)
            case $2 in
                build|exec|both)
                    type=$2
                    shift
                    ;;
                *)
                    print_error "Invalid type: $2"
                    print_usage
                    exit 1
                    ;;
            esac
            ;;
        --from-paths)
            while [[ $# -gt 1 && $2 != -* ]]; do
                from_paths+=($2)
                shift
            done
            if [[ ${#from_paths[@]} -eq 0 ]]; then
                print_error "No paths provided with --from-paths"
                print_usage
                exit 1
            fi
            ;;
        --skip-moveit-apt-removal)
            skip_moveit_apt_removal=true
            ;;
        --skip-apt)
            skip_apt=true
            ;;
        --skip-uv)
            skip_uv=true
            ;;
        *)
            print_error "Unknown argument $1"
            print_usage
            exit 1
            ;;
    esac
    shift
done
if [[ ${#from_paths[@]} -eq 0 ]]; then
    from_paths=("src/ros")
fi

# Upgrade apt packages
if [[ $skip_apt != true ]]; then
    print_status "Upgrading apt packages"
    sudo apt update -q
    sudo apt upgrade -q -y
    sudo apt dist-upgrade -q -y
    rosdep update -q
fi

# Install Python dependencies
if [[ $skip_uv != true ]]; then
    print_status "Installing Python dependencies using uv"
    uv sync $TT_UV_EXTRA
fi

# Remove any existing MoveIt2 debian packages
if [[ $type = build && $skip_moveit_apt_removal != true ]]; then
    print_status "Removing any existing MoveIt2 debian packages"
    sudo apt remove ros-$ROS_DISTRO-moveit* -qq -y
fi

# Source ROS environment again after rosdep update
if [[ $skip_apt != true || $skip_uv != true ]]; then
    source $TABLETOP_DIR/setup.bash
fi

# Install ROS 2 build dependencies
build_types="-t buildtool_export -t build -t build_export -t buildtool"
exec_types="-t exec"
case $type in
    build)
        type_string="build"
        dependency_types="$build_types"
        ;;
    exec)
        type_string="runtime"
        dependency_types="$exec_types"
        ;;
    both)
        type_string="build and runtime"
        dependency_types="$build_types $exec_types"
        ;;
    *)
        print_error "Invalid type: $type"
        print_usage
        exit 1
        ;;
esac

print_status "Installing ROS 2 $type_string dependencies from paths ${from_paths[@]}"
rosdep install -r --from-paths "${from_paths[@]}" --ignore-src --rosdistro $ROS_DISTRO $dependency_types -q -y
print_status "Successfully installed ROS 2 $type_string dependencies from paths ${from_paths[@]}"
