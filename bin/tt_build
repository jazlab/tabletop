#!/usr/bin/env bash

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../setup.bash
source /opt/ros/${ROS_DISTRO}/setup.bash

set -e

print_usage() {
    print_error "Usage: $0 [--debug] [--clean] [--clean-all] [--remove-moveit-apt] [-w|--workers <num_workers>] [-p|--packages <package_name>...] [--all]"
}

pushd $COLCON_WS

# Parse arguments
debug=false
clean=false
clean_all=false
remove_moveit_apt=false
workers=
packages=()
all=false
while [[ $# -gt 0 ]]; do
    case $1 in
        --debug)
            debug=true
            ;;
        --clean)
            clean=true
            ;;
        --clean-all)
            clean_all=true
            ;;
        -w|--workers)
            workers=$2
            shift
            ;;
        --remove-moveit-apt)
            remove_moveit_apt=true
            ;;
        -p|--packages)
            if [[ $# -le 1  || $2 == -* ]]; then
                print_error "No packages provided"
                print_usage
                exit 1
            fi
            while [[ $# -gt 1 && $2 != -* ]]; do
                packages+=($2)
                shift
            done
            ;;
        -a|--all)
            all=true
            ;;
        *)
            print_error "Unknown argument $1"
            print_usage
            exit 1
            ;;
    esac
    shift
done

if [ "$all" = "true" ]; then
    if [ ${#packages[@]} -gt 0 ]; then
        print_error "Cannot use --all with -p|--packages"
        print_usage
        exit 1
    fi
    package_selection=
elif [ ${#packages[@]} -gt 0 ]; then
    package_selection="--packages-above-and-dependencies ${packages[@]}"
else
    packages=(tabletop)
    package_selection="--packages-up-to tabletop"
fi

# Clean workspace
if [ "$clean_all" = "true" ]; then
    tt_clean_ws --all
elif [ "$clean" = "true" ]; then
    tt_clean_ws
fi

# Upgrade apt packages
print_status "Upgrading apt packages"
sudo apt update
sudo apt upgrade -y
sudo apt dist-upgrade -y
rosdep update

# Source ROS environment again after rosdep update
source /opt/ros/${ROS_DISTRO}/setup.bash

# Remove any existing MoveIt2 debian packages
if [ "$remove_moveit_apt" = "true" ]; then
    print_status "Removing any existing MoveIt2 debian packages"
    sudo apt remove -y ros-${ROS_DISTRO}-moveit* || true
fi

# Install ROS 2 dependencies
print_status "Installing ROS 2 dependencies"
rosdep install -r --from-paths src --ignore-src --rosdistro ${ROS_DISTRO} -y

# # Install Python dependencies
print_status "Installing extra Python dependencies using pip"
pip install --break-system-packages -r $TABLETOP_DIR/requirements.txt

# Set CMake arguments
cmake_args=("-DUAGENT_BUILD_EXECUTABLE=OFF" "-DUAGENT_P2P_PROFILE=OFF" "--no-warn-unused-cli")
if [ "$debug" = "true" ]; then
    cmake_args+=("-DCMAKE_BUILD_TYPE=Debug")
else
    cmake_args+=("-DCMAKE_BUILD_TYPE=Release")
fi

# Build ROS 2 packages
if [ -n "$workers" ]; then
    export MAKEFLAGS="-j$workers"
    parallel_workers="--parallel-workers $workers"
fi
command="colcon build \
--symlink-install \
--event-handlers console_cohesion+ \
--cmake-args "${cmake_args[@]}" \
$parallel_workers \
$package_selection
"
print_status "Building ROS 2 packages with command: $command"
$command

print_status "Successfully built ROS 2 packages!"

popd
