#!/usr/bin/env bash
# Clean build artifacts, caches, and logs with granular options
# Usage: tt-clean [-t|--tabletop-colcon] [-l|--logs] [-c|--tabletop-cache] [--all-colcon] [--ccache] [--everything]
# Runs on: host or container (accessible from both via PATH)
# Environment: TABLETOP_DIR, COLCON_WS, COLCON_LOG_DIR, ROS_LOG_DIR, CCACHE_DIR
# Logic: Parses flags to select which artifacts to remove (colcon, logs, caches); accumulates paths and deletes

set -eo pipefail

bin_dir=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
source "$bin_dir/../../setup.bash"
source "$bin_dir/../utils.sh"

print_usage() {
    echo "Usage: $0 [-t|--tabletop-colcon] [-l|--logs] [-c|--tabletop-cache] [--all-colcon] [--ccache] [--everything]"
}

if [[ "$#" < 1 ]]; then
    print_error "At least one option must be provided."
    print_usage
    exit 1
fi

# Parse arguments to select what to clean
tabletop_colcon=false
tabletop_cache=false
logs=false
all_colcon=false
ccache=false
all=false
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -t|--tabletop-colcon)
            # Remove only tabletop package build/install directories
            tabletop_colcon=true
            ;;
        -c|--tabletop-cache)
            # Remove tabletop cache directory
            tabletop_cache=true
            ;;
        -l|--logs)
            # Remove colcon and ROS log directories
            logs=true
            ;;
        --ccache)
            # Remove C compiler cache
            ccache=true
            ;;
        --all-colcon)
            # Remove all colcon build/install + logs + ccache
            all_colcon=true
            ccache=true
            ;;
        --everything)
            # Remove all caches, build artifacts, and logs
            all=true
            ;;
        *)
            print_error "Unknown argument: $1"
            print_usage
            exit 1
            ;;
    esac
    shift
done

# Accumulate paths to clean based on flags
if [[ "$all" == true || "$all_colcon" == true ]]; then
    to_clean+=("$COLCON_WS/build" "$COLCON_WS/install")
elif [[ "$tabletop_colcon" == true ]]; then
    to_clean+=("$COLCON_WS/build/tabletop*" "$COLCON_WS/install/tabletop*")
fi

if [[ "$all" == true || "$all_colcon" == true || "$logs" == true ]]; then
    to_clean+=("$COLCON_LOG_DIR" "$ROS_LOG_DIR")
fi

if [[ "$all" == true || "$tabletop_cache" == true ]]; then
    to_clean+=("$TABLETOP_CACHE_DIR")
fi

if [[ "$all" == true || "$all_colcon" == true || "$ccache" == true ]]; then
    to_clean+=("$CCACHE_DIR")
fi

print_status "Removing ${to_clean[@]}"
rm -rf ${to_clean[@]}
