#!/usr/bin/env bash

set -e

bin_dir=$(dirname $(realpath ${BASH_SOURCE[0]}))
source $bin_dir/../../setup.bash
source $bin_dir/../utils.sh

project_dir=$TABLETOP_DIR/src/ros/tabletop/tabletop_teensy

target_arg="--target upload"
compile=false
while [[ $# -gt 0 ]]; do
    case $1 in
        --clean)
            clean=true
            shift
            ;;
        --no-upload)
            unset target_arg
            shift
            ;;
        --compile)
            compile=true
            target_arg="--target compiledb"
            shift
            ;;
        -y)
            yes=true
            shift
            ;;
        *)
            echo "Error: Unknown argument $1"
            echo "Usage: $0 [--clean] [--no-upload]"
            exit 1
            ;;
    esac
done

if [[ $clean = true ]]; then
    if [[ $yes != true ]]; then
        read -p "Are you sure you want to clean the build directory? This will delete all build artifacts. [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Aborting clean operation"
            exit 0
        fi
    fi
    print_status "Cleaning build directory"
    sudo rm -rf $project_dir/.pio
fi

if [[ $compile = true ]]; then
    extra_script_path=$project_dir/.pio/libdeps/teensy41/micro_ros_platformio/extra_script.py
    if [[ -f $extra_script_path ]]; then
        cat << EOF >> $extra_script_path
env.Replace(COMPILATIONDB_INCLUDE_TOOLCHAIN=True)
env.Replace(
    COMPILATIONDB_PATH=os.path.join("$BUILD_DIR", "compile_commands.json")
)
EOF
    else
        print_error "Extra script not found at $extra_script_path"
        print_error "Please run without the --compile flag, then run with --compile"
        exit 1
    fi
fi

print_status "Building Teensy code"
while ! pio run $target_arg --project-dir $project_dir; do
    if [[ -n $target_arg ]]; then
        print_status "Build failed, retrying..."
        sleep 1
    else
        print_status "Build failed, aborting..."
        exit 1
    fi
done
