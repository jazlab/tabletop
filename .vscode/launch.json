{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ROS: Launch",
            "request": "launch",
            "type": "ros",
            "target": "/root/ws/install/tabletop_server/share/tabletop_server/launch/server.launch.py",
            "arguments": [
                "robot_ip:=192.168.12.10",
                "reverse_ip:=192.168.12.101"
            ],
            "preLaunchTask": "build_debug",
            "attachDebugger": [
                "commander"
            ]
        },
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        }
    ]
}