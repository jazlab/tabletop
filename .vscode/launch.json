{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: Launch run_tasks",
            "type": "debugpy",
            "request": "launch",
            "program": "/root/ws/install/tabletop_tasks/share/tabletop_tasks/launch/tasks.launch.py",
            "console": "integratedTerminal",
            "args": [
                "launch_server:=false",
                "task_config:=foraging_ordered.yaml"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: Attach to run_tasks",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 4567
            },
            "justMyCode": false
        },
        {
            "name": "ROS: Launch Commander",
            "request": "launch",
            "type": "ros",
            "target": "/root/ws/install/tabletop_server/share/tabletop_server/launch/commander.launch.py",
            "arguments": [
                "commander_log_level:=DEBUG"
            ],
            "attachDebugger": [
                "commander"
            ]
        },
        {
            "name": "ROS: Launch Tasks",
            "request": "launch",
            "type": "ros",
            "target": "/root/ws/install/tabletop_tasks/share/tabletop_tasks/launch/tasks.launch.py",
            "arguments": [
                "launch_server:=false",
                "clear_cache:=true"
            ],
            "attachDebugger": [
                "commander"
            ]
        },
        {
            "name": "ROS: Launch Real Robot",
            "request": "launch",
            "type": "ros",
            "target": "/root/ws/install/tabletop_tasks/share/tabletop_tasks/launch/tasks.launch.py",
            "arguments": [
                "robot_mode:=real"
            ],
            "attachDebugger": [
                "commander"
            ]
        }
    ],
    "inputs": [
        {
            "id": "task_config",
            "type": "pickString",
            "default": "foraging_ordered.yaml",
            "description": "Task configuration file",
            "options": [
                "task_config:=foraging_ordered.yaml",
                "task_config:=foraging_random.yaml",
                "task_config:=smooth_pursuit.yaml",
                "task_config:=dummy.yaml"
            ]
        }
    ]
}
