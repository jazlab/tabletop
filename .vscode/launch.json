{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: Current File with fixed Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "results/eyelink/latest.asc",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "ROS: Launch Commander",
            "request": "launch",
            "type": "ros",
            "target": "/root/ws/install/tabletop_server/share/tabletop_server/launch/server.launch.py",
            "arguments": [
                "use_mock_teensy:=true",
                "commander_log_level:=DEBUG"
            ],
            "attachDebugger": [
                "commander"
            ],
            "postDebugTask": "kill_ros"
        },
        {
            "name": "ROS: Launch Tasks",
            "request": "launch",
            "type": "ros",
            "target": "/root/ws/install/tabletop_tasks/share/tabletop_tasks/launch/tasks.launch.py",
            "arguments": [
                "robot_mode:=ursim",
                "use_mock_teensy:=true",
                "simulate_flic:=true",
                "task_config:=smooth_pursuit.yaml"
            ],
            "attachDebugger": [
                "run_tasks"
            ],
            "postDebugTask": "kill_ros"
        },
        {
            "name": "ROS: Launch Real Robot",
            "request": "launch",
            "type": "ros",
            "target": "/root/ws/install/tabletop_tasks/share/tabletop_tasks/launch/tasks.launch.py",
            "arguments": [
                "robot_mode:=real",
                "commander_log_level:=DEBUG"
            ],
            "attachDebugger": [
                "run_tasks"
            ],
            "postDebugTask": "kill_ros"
        }
    ]
}
