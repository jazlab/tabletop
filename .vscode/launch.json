{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Launch run_tasks",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/install/tabletop_tasks/share/tabletop_tasks/launch/tasks.launch.py",
            "console": "integratedTerminal",
            "args": [
                "launch_server:=false",
                "task_config:=foraging_ordered.yaml"
            ],
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Attach to commander",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 1300
            },
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Attach to flic",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 1301
            },
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Attach to mock teensy",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 1302
            },
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Attach to eyelink",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 1303
            },
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "task_config",
            "type": "pickString",
            "default": "foraging_ordered.yaml",
            "description": "Task configuration file",
            "options": [
                "task_config:=foraging_ordered.yaml",
                "task_config:=foraging_random.yaml",
                "task_config:=smooth_pursuit.yaml",
                "task_config:=dummy.yaml"
            ]
        }
    ]
}
