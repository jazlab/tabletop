{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "build_debug",
			"command": "./scripts/build.sh --debug",
			"problemMatcher": [
				"$catkin-gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"type": "shell",
			"label": "build_release",
			"command": "./scripts/build.sh",
			"problemMatcher": [
				"$catkin-gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}