{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "build_debug",
			"command": "${workspaceFolder}/scripts/build.sh --debug",
			"problemMatcher": [
				"$catkin-gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"type": "shell",
			"label": "build_release",
			"command": "${workspaceFolder}/scripts/build.sh",
			"problemMatcher": [
				"$catkin-gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "view_mesh",
			"command": "${workspaceFolder}/scripts/view_mesh.py",
			"args": [
				"${file}"
			],
			"problemMatcher": [],
			"group": "none"
		},
		{
			"type": "shell",
			"label": "clean_build_artifacts",
			"command": "${workspaceFolder}/scripts/clean_build_artifacts.sh",
			"problemMatcher": [],
			"group": "none"
		},
		{
			"type": "shell",
			"label": "kill_ros",
			"command": "${workspaceFolder}/scripts/kill_ros.sh",
			"problemMatcher": [],
			"group": "none"
		}
	]
}
