{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "build_debug",
			"command": "./scripts/build.sh --debug",
			"problemMatcher": [
				"$catkin-gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"type": "shell",
			"label": "build_release",
			"command": "./scripts/build.sh",
			"problemMatcher": [
				"$catkin-gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "launch_server",
			"command": "ros2 launch tabletop_server server.launch.py",
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "view_mesh",
			"command": "./scripts/view_mesh.py",
			"args": [
				"${file}"
			],
			"problemMatcher": [],
			"group": "none"
		},
		{
			"type": "shell",
			"label": "clean_ws",
			"command": "./scripts/clean_ws.sh",
			"problemMatcher": [],
			"group": "none"
		}
	]
}
