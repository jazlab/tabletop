<!-- Right Arm -->

<mujoco model="Right Arm V0">

  <!-- Component default parameters -->
  <default>
    <mesh scale="0.001 0.001 0.001"/>
    <joint type="hinge" pos="0 0 0" limited="true" damping="0.1" armature="0.1" stiffness="0.1"/>
    <geom type="mesh" rgba="0.8 0.6 .4 1" margin="0.001" density="1000"/>
    <site size="0.001"/>
    <tendon width="0.001" rgba=".95 .3 .3 1" limited="false"/>
    <muscle ctrllimited="true" ctrlrange="0.002 1" scale="2000"/>
    <motor gear="1" ctrlrange="-0.1 0.1"/>
  </default>

  <!-- Asset definitions for bones -->
  <asset>
    <mesh name="sternum" file="bones/sternum.stl"/>
    <mesh name="clavicle" file="bones/clavicle.stl"/>
    <mesh name="scapula" file="bones/scapula.stl"/>
    <mesh name="humerus" file="bones/humerus.stl"/>
    <mesh name="ulna" file="bones/ulna.stl"/>
    <mesh name="radius" file="bones/radius.stl"/>
    <mesh name="palm" file="bones/hand_bones/palm.stl"/>
    <mesh name="thumb_d0" file="bones/hand_bones/thumb_d0.stl"/>
    <mesh name="thumb_d1" file="bones/hand_bones/thumb_d1.stl"/>
    <mesh name="thumb_d2" file="bones/hand_bones/thumb_d2.stl"/>
    <mesh name="index_d0" file="bones/hand_bones/index_d0.stl"/>
    <mesh name="index_d1" file="bones/hand_bones/index_d1.stl"/>
    <mesh name="index_d2" file="bones/hand_bones/index_d2.stl"/>
    <mesh name="middle_d0" file="bones/hand_bones/middle_d0.stl"/>
    <mesh name="middle_d1" file="bones/hand_bones/middle_d1.stl"/>
    <mesh name="middle_d2" file="bones/hand_bones/middle_d2.stl"/>
    <mesh name="ring_d0" file="bones/hand_bones/ring_d0.stl"/>
    <mesh name="ring_d1" file="bones/hand_bones/ring_d1.stl"/>
    <mesh name="ring_d2" file="bones/hand_bones/ring_d2.stl"/>
    <mesh name="pinky_d0" file="bones/hand_bones/pinky_d0.stl"/>
    <mesh name="pinky_d1" file="bones/hand_bones/pinky_d1.stl"/>
    <mesh name="pinky_d2" file="bones/hand_bones/pinky_d2.stl"/>
  </asset>

  <!-- Avoid some contact forces -->
  <contact>
    <exclude body1="humerus" body2="scapula"/>
    <exclude body1="humerus" body2="radius"/>
    <exclude body1="radius_capsule" body2="radius"/>
    <exclude body1="radius_capsule" body2="ulna"/>
    <exclude body1="radius_capsule" body2="humerus"/>
    <exclude body1="ulna" body2="radius"/>
    <exclude body1="palm" body2="thumb"/>
    <exclude body1="palm" body2="index"/>
    <exclude body1="palm" body2="middle"/>
    <exclude body1="palm" body2="ring"/>
    <exclude body1="palm" body2="pinky"/>
  </contact>

  <!-- Make arm body -->
  <worldbody>
    <body name="sternum" pos="0 0 0" quat="0.7071067811865475 0.7071067811865475 0.0 0.0">
      <geom name="sternum" mesh="sternum"/>
      <body name="clavicle" pos="0 0 0" quat="1.0 0.0 0.0 0.0">
        <geom name="clavicle" mesh="clavicle"/>
        <body name="scapula" pos="0 0 0" quat="1.0 0.0 0.0 0.0">
          <geom name="scapula" mesh="scapula"/>
          <body name="humerus" pos="0.005 -0.005 0.005" quat="1.0 0.0 0.0 0.0">
            <geom name="humerus" mesh="humerus"/>
            <joint name="shoulder_abduction" axis="-1 0 0" range="-15 120"/>
            <joint name="shoulder_flexion" axis="0 0 1" range="-120 120"/>
            <joint name="shoulder_rotation" axis="0 1 0" range="-30 30"/>
            <body name="ulna" pos="-0.00 -0.125 -0.003" quat="1.0 0.0 0.0 0.0">
              <geom name="ulna" mesh="ulna"/>
              <joint name="elbow_flexion" axis="0 0 1" range="0 120"/>
              <body name="radius_capsule" pos="0 -0.010 0.005" quat="0.9998209174098923 0.01775660138237004 -0.00011621834917850029 0.0065439063474658">
                <joint name="radial_pronation" axis="0 1 0" range="-90 120"/>
                <body name="radius" pos="0 0 0" quat="0.9998209174098923 -0.01775660138237004 -0.00011621834917850029 -0.0065439063474658">
                  <geom name="radius" mesh="radius"/>
                  <body name="hand" pos="0.007 -0.132 -0.0015" quat="1.0 0.0 0.0 0.0">
                    <include file="right_hand_v0.xml"/>
                    <joint name="wrist_flexion" axis="1 0 0" range="-30 30"/>
                    <joint name="wrist_abduction" axis="0 0 1" range="-30 30"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Joint actuators -->
  <actuator>
    <motor name="shoulder_abduction" joint="shoulder_abduction"/>
    <motor name="shoulder_flexion" joint="shoulder_flexion" gear="1" ctrlrange="-1 1"/>
    <motor name="shoulder_rotation" joint="shoulder_rotation"/>
    <motor name="elbow_flexion" joint="elbow_flexion"/>
    <motor name="radial_pronation" joint="radial_pronation" gear="5"/>
    <motor name="wrist_flexion" joint="wrist_flexion"/>
    <motor name="wrist_abduction" joint="wrist_abduction"/>
    <motor name="thumb_d0_abduction" joint="thumb_d0_abduction"/>
    <motor name="thumb_d0_flexion" joint="thumb_d0_flexion"/>
    <motor name="thumb_d1_flexion" joint="thumb_d1_flexion"/>
    <motor name="thumb_d2_flexion" joint="thumb_d2_flexion"/>
    <motor name="index_d0_flexion" joint="index_d0_flexion"/>
    <motor name="index_d1_flexion" joint="index_d1_flexion"/>
    <motor name="index_d2_flexion" joint="index_d2_flexion"/>
    <motor name="middle_d0_flexion" joint="middle_d0_flexion"/>
    <motor name="middle_d1_flexion" joint="middle_d1_flexion"/>
    <motor name="middle_d2_flexion" joint="middle_d2_flexion"/>
    <motor name="ring_d0_flexion" joint="ring_d0_flexion"/>
    <motor name="ring_d1_flexion" joint="ring_d1_flexion"/>
    <motor name="ring_d2_flexion" joint="ring_d2_flexion"/>
    <motor name="pinky_d0_flexion" joint="pinky_d0_flexion"/>
    <motor name="pinky_d1_flexion" joint="pinky_d1_flexion"/>
    <motor name="pinky_d2_flexion" joint="pinky_d2_flexion"/>
  </actuator>

</mujoco>
