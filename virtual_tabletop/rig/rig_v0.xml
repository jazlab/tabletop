<!-- Rig -->

<mujoco model="Rig V0">

  <!-- Component default parameters -->
  <default>
    <mesh scale="1 1 1"/>
    <geom type="mesh" rgba="0.3 0.3 .3 0.5" margin="0.0001" density="1000"/>
  </default>

  <!-- Asset definitions for bones -->
  <asset>
    <mesh name="rig" file="./compressed_rig_v0.stl"/>
  </asset>

  <!-- Make rig body -->
  <worldbody>
    <body name="rig" pos="0.7 0 -0.5" quat="1.0 1.0 0.0 0.0">
      <geom name="rig" mesh="rig" contype="2" conaffinity="0"/>
    </body>
  </worldbody>

</mujoco>
