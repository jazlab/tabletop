    <geom type="box" rgba="0.5 0.5 0.5 1" size="0.02 1.02 0.02"/>
  </default>
  <worldbody>
    <body name="rig" quat="1 0 0 1">
      <inertial mass="100" pos="0 0 0"/>
      <geom name="front_bottom" pos="0 0 0" quat="1 0 1 0"/>
      <geom name="front_top" pos="0 0 2" quat="1 0 1 0"/>
      <geom name="front_left" pos="0 1 1" quat="1 1 0 0"/>
      <geom name="front_right" pos="0 -1 1" quat="1 1 0 0"/>
      <geom name="back_bottom" pos="2 0 0" quat="1 0 1 0"/>
      <geom name="back_top" pos="2 0 2" quat="1 0 1 0"/>
      <geom name="back_left" pos="2 1 1" quat="1 1 0 0"/>
      <geom name="back_right" pos="2 -1 1" quat="1 1 0 0"/>
      <geom name="depth_top_left" pos="1 -1 0" quat="0 1 1 0"/>
      <geom name="depth_top_right" pos="1 -1 2" quat="0 1 1 0"/>
      <geom name="depth_bottom_left" pos="1 1 0" quat="0 1 1 0"/>
      <geom name="depth_bottom_right" pos="1 1 2" quat="0 1 1 0"/>
    </body>
  </worldbody>
</mujoco>
