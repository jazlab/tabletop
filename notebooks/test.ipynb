   "source": [
    "import hashlib\n",
    "\n",
    "hash_algorithm = hashlib.md5()\n",
    "with open(\n",
    "    \"/root/ws/src/tabletop/ros/tabletop_moveit_config/meshes/rig/rig_mod.dae\",\n",
    "    \"rb\",\n",
    ") as f:\n",
    "    while chunk := f.read(8192):\n",
    "        hash_algorithm.update(chunk)\n",
    "\n",
    "print(hash_algorithm.hexdigest())"
   ]
