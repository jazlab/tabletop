# Start Eyelink sample recording and open the EDF data file for a session.
# Served by: eyelink node (nodes/eyelink.py).
# Called by: EyelinkInterface or Commander to begin eye-tracking data collection at trial start.

# --- Request ---
string session_bag_dir  # Absolute path to the session directory where the rosbag and EDF data files will be saved
---
# --- Response ---
bool success    # True if recording started successfully
string message  # Human-readable status or error description
