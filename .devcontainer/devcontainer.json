{
  "name": "tabletop-dev",
  "dockerComposeFile": "../compose.yaml",
  "service": "dev",
  "runServices": [
    "dev"
  ],
  "workspaceFolder": "/tabletop",
  "containerUser": "mules",
  "remoteUser": "mules",
  "mounts": [
    "source=claude-code-config,target=/home/mules/.claude,type=volume"
  ],
  "postCreateCommand": [
    "bash",
    "-c",
    "cd /tabletop && source /tabletop/setup.bash && (command -v pre-commit && pre-commit install-hooks; sudo chown -R mules:mules /home/mules/.claude)"
  ],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "instalZsh": false
    },
    "ghcr.io/devcontainers/features/git-lfs:1": {},
    "ghcr.io/schlich/devcontainer-features/starship:0": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "mechatroner.rainbow-csv",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-xml",
        "bierner.markdown-mermaid",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cpptools-themes",
        "ms-vscode.cmake-tools",
        "ms-toolsai.jupyter",
        "mads-hartmann.bash-ide-vscode",
        "docker.docker",
        "DavidAnson.vscode-markdownlint",
        "benjamin-simmonds.pythoncpp-debug"
      ]
    }
  }
}
