{
    "name": "Tabletop Dev Container",
    "dockerComposeFile": "compose.devcontainer.yaml",
    "service": "devcontainer",
    "workspaceFolder": "/root/ws/src/tabletop",
    "postStartCommand": [
        "bash",
        "-c",
        "tt_build --remove-moveit-apt && pip install -r /root/ws/src/tabletop/requirements-dev.txt && print_status 'Successfully installed pip development dependencies!'"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "mechatroner.rainbow-csv",
                "charliermarsh.ruff",
                "tamasfe.even-better-toml",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker",
                "redhat.vscode-xml",
                "bierner.markdown-mermaid",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cpptools-themes",
                "ms-vscode.cmake-tools",
                "IronGeek.vscode-env",
                "ms-toolsai.jupyter",
                "anysphere.cpptools"
            ]
        }
    }
}
