<!-- TableTop -->

<mujoco model="TableTop V0">
  <option timestep="0.01"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="floor" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="floor" texture="floor" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    <model name="right_arm" file="monkey_arm/right_arm_v0.xml"/>
    <model name="robot" file="universal_robots_ur5e/ur5e.xml"/>
    <model name="rig" file="rig/rig_v0.xml"/>
  </asset>

  <worldbody>

    <!-- Lighting -->
    <light directional="true" diffuse=".4 .4 .4" specular="0.1 0.1 0.1" pos="0 0 5" dir="0 0 -1" castshadow="false"/>
    <light name="spotlight" mode="targetbodycom" target="world" diffuse="1 1 1" specular="0.3 0.3 0.3" pos="-2 -2 1" cutoff="60"/>

    <!-- Floor -->
    <geom name="floor" pos="0 0 0" size="2 2 .05" type="plane" material="floor" condim="3"/>

    <!-- Rig -->
    <frame pos="0 0 0">
      <attach model="rig" body="rig"/>
    </frame>

    <!-- Robot -->
    <frame pos="-0.3 0.75 0">
      <attach model="robot" body="base"/>
    </frame>

    <!-- Right arm -->
    <frame pos="0 0 0.7" quat="1 0 0 1">
      <attach model="right_arm" body="sternum"/>
    </frame>

  </worldbody>
</mujoco>
